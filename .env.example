# Base transformer checkpoint used for fine-tuning
BASE_MODEL_NAME=distilbert-base-uncased

# Where the fine-tuned model is saved to / loaded from
MODEL_DIR=models/sentiment_model

# Training hyperparameters
NUM_TRAIN_EPOCHS=4
TRAIN_BATCH_SIZE=16
EVAL_BATCH_SIZE=32
LEARNING_RATE=2e-5
WEIGHT_DECAY=0.01
TEST_SIZE=0.2
RANDOM_SEED=42

# Below this confidence, predictions are flagged as uncertain
LOW_CONFIDENCE_THRESHOLD=0.60

LOG_LEVEL=INFO
